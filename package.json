{
  "name": "byte-snap",
  "version": "1.0.4",
  "type": "module",
  "description": "Size matters. Snapshot and diff file sizes around any build step — a universal byte meter for Vite, Rollup, webpack, esbuild & more.",
  "keywords": [
    "size",
    "bundle-size",
    "filesize",
    "diff",
    "snapshot",
    "measure",
    "bytes",
    "build",
    "vite-plugin",
    "rollup-plugin",
    "webpack-plugin",
    "esbuild-plugin",
    "unplugin"
  ],
  "license": "MIT",
  "author": "jayF0x",
  "repository": {
    "type": "git",
    "url": "https://github.com/jayf0x/byte-snap"
  },
  "homepage": "https://github.com/jayF0x/byte-snap#readme",
  "bugs": {
    "url": "https://github.com/jayF0x/byte-snap/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.js --outdir dist --entry-naming index.js --target node --format esm --external unplugin && cp src/index.d.ts dist/index.d.ts",
    "typecheck": "tsc --noEmit --strict --skipLibCheck src/index.d.ts",
    "test": "bun test",
    "test:run": "bun test",
    "test:e2e": "cd tests && bun install && node e2e.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "npm:deploy": "bash ./scripts/publish-npm.sh",
    "rm:stalepr": "git branch -vv | grep '\\[gone\\]' | awk '{print $1}' | xargs git branch -D"
  },
  "dependencies": {
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0"
  }
}
