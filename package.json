{
  "name": "byte-snap",
  "version": "1.0.5",
  "sideEffects": false,
  "type": "module",
  "description": "Size matters. Snapshot and diff file sizes around any build step — a universal byte meter for Vite, Rollup, webpack, esbuild & more.",
  "keywords": [
    "size",
    "bundle-size",
    "bundle",
    "bundler",
    "filesize",
    "file-size",
    "diff",
    "snapshot",
    "measure",
    "bytes",
    "byte-counter",
    "build",
    "build-size",
    "dist-size",
    "output-size",
    "size-check",
    "size-limit",
    "performance",
    "minify",
    "compression",
    "gzip",
    "brotli",
    "vite-plugin",
    "rollup-plugin",
    "webpack-plugin",
    "esbuild-plugin",
    "rspack-plugin",
    "rolldown-plugin",
    "farm-plugin",
    "unplugin"
  ],
  "license": "MIT",
  "author": "jayF0x",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayf0x/byte-snap.git"
  },
  "homepage": "https://github.com/jayf0x/byte-snap#readme",
  "bugs": {
    "url": "https://github.com/jayf0x/byte-snap/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && esbuild src/index.js --bundle --outfile=dist/index.js --platform=node --format=esm --external:unplugin && cp src/index.d.ts dist/index.d.ts && bun build src/index.js --outdir dist --entry-naming index.cjs --target node --format cjs --external unplugin",
    "typecheck": "tsc --noEmit --strict --skipLibCheck src/index.d.ts",
    "test": "bun test",
    "test:run": "bun test",
    "test:e2e": "cd tests && bun install && node e2e.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "npm:deploy": "bash ./scripts/publish-npm.sh",
    "rm:stalepr": "git branch -vv | grep '\\[gone\\]' | awk '{print $1}' | xargs git branch -D",
    "size": "size-limit"
  },
  "dependencies": {
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@size-limit/file": "^11.0.0",
    "@trivago/prettier-plugin-sort-imports": "^5.0.0",
    "byte-snap": "^1.0.5",
    "esbuild": "^0.25.0",
    "prettier": "^3.0.0",
    "size-limit": "^11.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "1.3 kB"
    }
  ]
}
